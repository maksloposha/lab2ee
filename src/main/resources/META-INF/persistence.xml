<?xml version="1.0" encoding="UTF-8"?>
<persistence xmlns="https://jakarta.ee/xml/ns/persistence"
             xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
             xsi:schemaLocation="https://jakarta.ee/xml/ns/persistence
             https://jakarta.ee/xml/ns/persistence/persistence_3_0.xsd"
             version="3.0">

    <persistence-unit name="FoodOrderingPU" transaction-type="JTA">

        <jta-data-source>jdbc/FoodOrderingDS</jta-data-source>

        <class>org.example.lab2ee.model.MenuItem</class>
        <class>org.example.lab2ee.model.Order</class>
        <class>org.example.lab2ee.model.OrderItem</class>
        <class>org.example.lab2ee.model.User</class>

        <properties>
            <property name="jakarta.persistence.schema-generation.database.action"
                      value="none"/>

            <property name="eclipselink.logging.level.sql"  value="FINE"/>
            <property name="eclipselink.logging.parameters" value="true"/>
        </properties>
    </persistence-unit>
</persistence>